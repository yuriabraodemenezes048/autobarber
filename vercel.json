{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/jsonblob",
      "destination": "https://jsonblob.com/api/jsonBlob"
    },
    {
      "source": "/api/jsonblob/:path*",
      "destination": "https://jsonblob.com/api/jsonBlob/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self'"
        }
      ]
    }
  ]
}
